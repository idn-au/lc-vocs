PREFIX bccs: <https://data.idnau.org/pid/vocab/bc-labels>
PREFIX idn: <https://linked.data.gov.au/org/idn>
PREFIX kai: <https://kurrawong.ai>
PREFIX lcncs: <https://data.idnau.org/pid/vocab/lc-notices>
PREFIX lcont: <https://data.idnau.org/pid/lc-ont#>
PREFIX odrl: <http://www.w3.org/ns/odrl/2/>
PREFIX ont: <https://data.idnau.org/pid/lc-ont>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sdo: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX tkcs: <https://data.idnau.org/pid/vocab/tk-labels>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

lcont:followProtocol a odrl:Action ;
    rdfs:isDefinedBy lcont: ;
    skos:prefLabel "Follow protocol"@en ;
    skos:definition "A label to be applied to data that indicates that a protocol must be followed" ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Follow Protocol" .

lcont:relatedNotice a owl:Property ;
    rdfs:domain lcont:BCLabel,
        lcont:TKLabel ;
    rdfs:isDefinedBy lcont: ;
    rdfs:range lcont:LCNotice ;
    skos:definition "A relationship that indicates that a Traditional Knowledge Label or Biocultural Label is related in some way to a Local Contexts Notice" ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Related Notice" .

lcont:templateText a owl:DatatypeProperty ;
    rdfs:domain lcont:BCLabel,
        lcont:LCNotice,
        lcont:TKLabel ;
    rdfs:isDefinedBy lcont: ;
    rdfs:range rdf:langString ;
    skos:definition "A prescriptive text string associated with a Label or Notice that provides boilerplate wording intended to be reused or customised by end-users. Distinct from skos:example, which is illustrative only." ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Template Text" .

lcont:BCLabel a owl:Class ;
    rdfs:isDefinedBy lcont: ;
    skos:definition "A label to be applied to data that define community expectations about appropriate use of biocultural collections and data. The BC Labels focus on accurate provenance, transparency and integrity in research engagements with Indigenous communities. The BC Labels ensure Indigenous people are represented in the metadata and create opportunities for future researchers to connect and support appropriate benefit sharing." ;
    sdo:description "A SKOS Concept representing a Biocultural Label from the Local Contexts framework." ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Biocultural Label" .

lcont:LCNotice a owl:Class ;
    rdfs:isDefinedBy lcont: ;
    skos:definition "The class of all Notice concepts from the Local Contexts framework."@en ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Local Contexts Notice"@en .

lcont:TKLabel a owl:Class ;
    rdfs:isDefinedBy lcont: ;
    sdo:description "A SKOS Concept representing a Traditional Knowledge Label from the Local Contexts framework." ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Traditional Knowledge Label" .

lcont:QualifiedLocalContext a owl:Class ;
    rdfs:isDefinedBy lcont: ;
    skos:definition "An association between an RDF Resource and a Traditional Knowledge Label or Biocultural Label that allows for the nature of the relationship to be defined" ;
    skos:historyNote "Defined here for the first time in the Local Contexts Label Extension Vocabulary" ; 
    sdo:name "Qualified Local Context" ;
    rdfs:range lcont:BCLabel , lcont:TKLabel .

lcont: a owl:Ontology ;
    rdfs:seeAlso bccs:,
        lcncs:,
        tkcs: ;
    owl:versionIRI lcont:0.2 ;
    skos:historyNote """2026-02 NJC: made OntPub-conformant; 
2025-09 LK: created; 
2026-03 LK: harmonised draft and new work""" ;
    sdo:codeRepository "https://github.com/idn-au/refdata-catalogue"^^xsd:anyURI ;
    sdo:copyrightHolder kai: ;
    sdo:copyrightNotice "KurrawongAI, 2026" ;
    sdo:copyrightYear "2026"^^xsd:gYear ;
    sdo:creator kai: ;
    sdo:dateCreated "2025-09-23"^^xsd:date ;
    sdo:dateIssued "2026-03-31"^^xsd:date ;
    sdo:dateModified "2026-03-31"^^xsd:date ;
    sdo:description "Defines lcont:TKLabel and lcont:BCLabel classes as subclasses of skos:Concept, and lcont:templateText for associating reusable boilerplate text with Local Contexts labels." ;
    sdo:license "http://purl.org/NET/rdflicense/cc-by4.0"^^xsd:anyURI ;
    sdo:name "Local Contexts Label Extension Vocabulary" ;
    sdo:publisher idn: ;
    sdo:version "0.3" .
