[ rdf:type            odrl:Duty;
  odrl:action         odrl:inform;
  odrl:informedParty  odrl:public
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between authorized and/or initiated women within the community."@en;
  odrl:assignee        "women in the community"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between women in the community"@en;
  odrl:assignee        "women in the community"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Duty;
  dcterms:description  "external users shall discuss potential use of materials"@en;
  odrl:assignee        "external users"@en;
  odrl:purpose         odrl:obtainConsent
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material has seasonal conditions of access and use"@en;
  odrl:purpose         odrl:event
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "materials may be used for educational outreach activities"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "materials may be open ot research collaborations"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Prohibition;
  dcterms:description  "commercialization opportunities may not be derived from cultural material"@en;
  odrl:action          odrl:commercialize;
  odrl:purpose         odrl:prohibit
] .

[ rdf:type              cc:Attribution;
  dcterms:description   "multiple communities have responsibilities of custodianship and/or ownership over specific material"@en;
  odrl:attributedParty  "multiple communities"@en
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between authorized and/or initiated men in the community"@en;
  odrl:assignee        "men in the community"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between men in the community"@en;
  odrl:assignee        "men in the community"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between family."@en;
  odrl:assignee        "family"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Action;
  dcterms:description  "community members are encouraged to share their knowledge, stories and experiences"@en;
  odrl:assignee        "community members"
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between family, clan or community."@en;
  odrl:assignee        "community"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "commercialization opportunities may be derived from cultural material"@en;
  odrl:action          odrl:commercialize;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type             odrl:Permission;
  dcterms:description  "material circulating may be shared between clan members and/or according to protocols for clan relationships."@en;
  odrl:assignee        "clan"@en;
  odrl:purpose         odrl:grantUse
] .

[ rdf:type              cc:Attribution;
  dcterms:description   "attribute the correct sources, custodians, or owners"@en;
  odrl:attributedParty  "custodians or owners"@en
] .

bccs:   rdf:type            skos:ConceptScheme;
        dcterms:created     "2022-06-22"^^xsd:date;
        dcterms:creator     idn:;
        dcterms:identifier  "bc"^^xsd:token;
        dcterms:modified    "2026-02-18"^^xsd:date;
        dcterms:provenance  "This vocabulary was generated from the https://localcontexts.org website's content: https://localcontexts.org/labels/biocultural-labels/";
        dcterms:publisher   idn:;
        owl:versionInfo     "1.1";
        skos:definition     "Biocultural Labels define community expectations about appropriate use of biocultural collections and data. The BC Labels focus on accurate provenance, transparency and integrity in research engagements with Indigenous communities. The BC Labels ensure Indigenous people are represented in the metadata and create opportunities for future researchers to connect and support appropriate benefit sharing."@en;
        skos:hasTopConcept  bc:non-commercial , bc:outreach , bc:open-to-commercialization , bc:open-to-collaboration , bc:provenance , bc:multiple-communities , bc:clan , bc:consent-verified , bc:consent-non-verified , bc:research-use;
        skos:prefLabel      "Biocultural Labels"@en;
        sdo:citation        "https://localcontexts.org/labels/biocultural-labels/"^^xsd:anyURI .
