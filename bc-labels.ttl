PREFIX bccs: <https://data.idnau.org/pid/vocab/bc-labels>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX lcn: <https://data.idnau.org/pid/vocab/lc-notices/>
PREFIX lcont: <https://data.idnau.org/pid/lc-ont/>
PREFIX odrl: <http://www.w3.org/ns/odrl/2/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sdo: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX tk: <https://data.idnau.org/pid/vocab/tk-labels/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

bccs:
    a skos:ConceptScheme ;
    dcterms:created "2022-06-22"^^xsd:date ;
    dcterms:creator <https://linked.data.gov.au/org/idn> ;
    dcterms:identifier "bc"^^xsd:token ;
    dcterms:modified "2026-02-18"^^xsd:date ;
    dcterms:provenance "This vocabulary was generated from the https://localcontexts.org website's content: https://localcontexts.org/labels/biocultural-labels/" ;
    dcterms:publisher <https://linked.data.gov.au/org/idn> ;
    sdo:citation "https://localcontexts.org/labels/biocultural-labels/"^^xsd:anyURI ;
    owl:versionInfo "1.1"^^xsd:string ;
    skos:definition "Biocultural Labels define community expectations about appropriate use of biocultural collections and data. The BC Labels focus on accurate provenance, transparency and integrity in research engagements with Indigenous communities. The BC Labels ensure Indigenous people are represented in the metadata and create opportunities for future researchers to connect and support appropriate benefit sharing."@en ;
    skos:hasTopConcept
        bc:provenance ,
        bc:multiple-communities ,
        bc:clan ,
        bc:consent-verified ,
        bc:consent-non-verified ,
        bc:research-use ,
        bc:open-to-collaboration ,
        bc:open-to-commercialization ,
        bc:outreach ,
        bc:non-commercial ;
    skos:prefLabel "Biocultural Labels"@en ;
.

<https://linked.data.gov.au/org/idn>
    a sdo:Organization ;
    sdo:name "Indigenous Data Network" ;
    sdo:url "https://mspgh.unimelb.edu.au/centres-institutes/centre-for-health-equity/research-group/indigenous-data-network"^^xsd:anyURI ;
.

bc:collection-provenance
    a skos:Collection ;
    skos:member 
      bc:clan ,
      bc:provenance ,
      bc:multiple-communities ; 
    skos:inSchme bccs: ;
    sdo:citation "https://localcontexts.org/labels/biocultural-labels/"^^xsd:anyURI ;
    skos:prefLabel "Biocultural Provenance Labels Collection" ;
    skos:definition "Collection of Biocultural Labels that identify the group or sub-group which is the primary cultural authority for the material, and/or recognizes other interest in the materials."@en ;
    dcterms:created "2026-02-18"^^xsd:date
.

bc:collection-protocol
    a skos:Collection ;
    skos:member 
      bc:consent-verified ,
      bc:consent-non-verified ;
    skos:inSchme bccs: ;
    sdo:citation "https://localcontexts.org/labels/biocultural-labels/"^^xsd:anyURI ;
    skos:prefLabel "Biocultural Protocol Labels Collection" ;
    skos:definition "Collection of Biocultural Labels that outline traditional protocols associated with access to this material and invite viewers to respect community protocols."@en ;
    dcterms:created "2026-02-18"^^xsd:date
.

bc:collection-permission
    a skos:Collection ;
    skos:member 
      bc:research-use ,
      bc:non-commercial ,
      bc:open-to-commercialization ,
      bc:open-to-collaboration ,
      bc:outreach ;
    skos:inSchme bccs: ;
    sdo:citation "https://localcontexts.org/labels/biocultural-labels/"^^xsd:anyURI ;
    skos:prefLabel "Biocultural Permission Labels Collection" ;
    skos:definition "Collection of Biocultural Labels that indicate what activities the community has approved as generally acceptable. Other uses require direct engagement with primary cultural authorities."@en ;
    dcterms:created "2026-02-18"^^xsd:date
.


bc:provenance
    a lcont:BCLabel, skos:Concept , odrl:Policy ;
    skos:prefLabel "Provenance"@en ;
    dcterms:identifier "provenance"^^xsd:token ;
    skos:notation "BC P" ;
    sdo:citation "https://localcontexts.org/label/bc-provenance/"^^xsd:anyURI ;
    skos:definition "Indigenous peoples have the right to make decisions about the future use of information, biological collections, data, and digital sequence information (DSI) that derives from associated lands, waters and territories. This Label reflects a significant relationship and responsibility to the species or biological entity and associated scientific collections and data, and supports the practice of proper and appropriate acknowledgement into the future."@en ;
    lcont:templateText """This Label is being used to affirm an inherent interest Indigenous people have in the scientific collections and data about communities, peoples, and the biodiversity found within traditional lands, waters and territories. [Community name or authorizing party] retains the right to be named and associated with it into the future. This association reflects a significant relationship and responsibility to [the species or biological entity] and associated scientific collections and data.

[Optional attribution statement]"""@en ;
    skos:example "This Label is being used to affirm an inherent interest Te Roroa people have in the scientific collections and data (including Digital Sequence Information) about communities, peoples, and the biodiversity found within traditional lands, waters and territories. Te Roroa retains the right to be named and associated with it into the future. This association reflects a significant relationship and responsibility to biocultural materials from within the rohe of Te Roroa and associated scientific collections and data."@en ;
    lcont:relatedNotice lcn:attribution ;
    skos:relatedMatch tk:attribution ;
    skos:inScheme bccs: ;
    rdfs:isDefinedBy bccs:
.

bc:multiple-communities
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "multiple-communities"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-multiple-communities/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "This Label should be used to indicate that multiple communities have responsibility, custodianship and/or ownership over the geographic regions where this species or biological entity originates/is found. This Label recognizes that whilst one community might exert specific authority, other communities also have rights and responsibilities for use and care."@en ;
    lcont:templateText "This Label is being used to affirm that responsibility and ownership over this information, collection, data, and digital sequence information (DSI) is spread across several distinct communities. Use will be dependent upon discussion and negotiation with these multiple communities."@en ;  
    skos:example ""@en ; 
    lcont:relatedNotice lcn:attribution-incomplete ;
    skos:relatedMatch tk:multiple-communities ;
    skos:inScheme bccs: ;
    skos:notation "BC MC" ;
    skos:prefLabel "Multiple Communities"@en ;
.

bc:clan
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "clan"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-clan/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "This Label should be used when you would like external users to know that this material is subject to conditions for circulation relating to clan membership and/or is according to protocols for clan relationships. Because these conditions have not historically been recognized, this Label helps make these conditions for use and circulation clearer. Specifically, the Label asks future users to respect culturally specific rules of use and to make informed decisions about using this type of material."@en ;
    lcont:templateText "This Label is being used to indicate that this material is traditionally and usually not publicly available. The Label lets future users know that this data has specific conditions for use and sharing because of clan membership and/or relationships. This Label asks viewers of this data to respect the cultural values and expectations about circulation and use defined by designated clans, members, and their internal relations."@en ;    
    skos:example ""@en ; 
    lcont:relatedNotice lcn:belonging ;
    skos:relatedMatch tk:clan ;
    skos:inScheme bccs: ;
    skos:notation "BC CL" ;
    skos:prefLabel "Clan"@en ;
.

bc:consent-verified
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "consent-verified"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-consent-verified/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "Indigenous peoples have the right to permission the use of information, biological collections, data, and digital sequence information (DSI) that derives from associated lands, waters and territories. This Label verifies that there are consent conditions in place for uses of information, collections, data, and digital sequence information."@en ;
    lcont:templateText "This Label is being used to verify that [community name or authorizing party] have consent conditions in place for the use of this information, collections, data, and digital sequence information. [These can be found at ….]."@en ;  
    skos:example "This Label is being used to verify that the Kichwa Indigenous People of Sarayaku, their protective beings, nature, and territory have the appropriate conditions of consent regarding the use of this information, collection, data and digital sequence information. Such verification can be found as part of the research process carried out by the Kichwa Indigenous People of Sarayaku, their protectors, nature, and territory for the research related to the mushrooms and their mycorrhizal networks that live in the Sarayaku territory."@en ; 
    skos:relatedMatch tk:verified ;
    lcont:relatedNotice lcn:authorization ;
    skos:inScheme bccs: ;
    skos:notation "BC CV" ;
    skos:prefLabel "Consent Verified"@en ;
.

bc:consent-non-verified
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "consent-non-verified"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-consent-non-verified/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "The consent associated with this data has not been verified by the community. Reasons for this could include that it has not been appropriately vetted, has mistakes, omissions, lack of informed consent, or its process of creation was through research which did not follow proper community protocols."@en ;
    lcont:templateText "This Label is being used because there are concerns about the accuracy of the consent and/or representations made for this data. This material was not created through informed consent or community protocols for research and engagement."@en ; 
    skos:example ""@en ; 
    skos:relatedMatch tk:non-verified ;
    lcont:relatedNotice lcn:authorization ;
    skos:inScheme bccs: ;
    skos:notation "BC CNV" ;
    skos:prefLabel "Consent Non-Verified"@en ;
.

bc:research-use
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "research-use"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-research-use/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "This Label should be used to permission use of information, collections, data, and digital sequence information (DSI) for unspecified research. This Label does not give permission for commercialization activities."@en ;
    lcont:templateText """This Label is being used by [community name or authorizing body] to allow this information, collection, data, and digital sequence information (DSI) to be used for unspecified research purposes. This Label does not provide permission for commercialization activities.

[Optional return of research results statement]"""@en ;    
    skos:example "This Label is being used by the Kichwa Indigenous People of Sarayaku, their protective beings, nature, and territory to recognize that they allow the use of this information, data and digital sequence information for non-specific research purposes. However any specific use should be accepted, recognized, and validated by the Governing Council of the Kichwa Indigenous People of Sarayaku. This Label does not provide permission for commercial activities. Anyone interested in accessing this information should contact the Governing Council of the Kichwa Indigenous People of Sarayaku and obtain the consent of the Sarayaku People."@en ; 
    odrl:relatedNotice lcn:open-to-collaborate ;
    skos:relatedMatch tk:open-to-collaboration ;
    skos:inScheme bccs: ;
    skos:notation "BC R" ;
    skos:prefLabel "Research Use"@en ;
.

bc:open-to-collaboration
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "open-to-collaboration"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-open-to-collaboration/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "This Label is being used to indicate that the community is open to research collaborations and outreach activities. With this Label, future opportunities for collaboration and engagement are supported."@en ;
    lcont:templateText "This Label is being used to make clear [community name or authorizing body] is open to future engagement, collaboration, and partnership around research and outreach opportunities."@en ;
    skos:example "The Kichwa Indigenous People of Sarayaku, their protectors, nature, and territory are willing to collaborate with external actors in projects or activities related to this information. However, any type of collaboration and use of this information must be done with the consent of the Governing Council of the Kichwa Indigenous People of Sarayaku, their protectors, nature, and territory."@en ; 
    odrl:relatedNotice lcn:open-to-collaborate ;
    skos:relatedMatch tk:k:open-to-collaboration ;
    skos:inScheme bccs: ;
    skos:notation "BC CB" ;
    skos:prefLabel "Open To Collaboration"@en ;
.

bc:open-to-commercialization
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "open-to-commercialization"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-open-to-commercialization/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "Indigenous peoples have the right to benefit from information, biological collections, data, and digital sequence information (DSI) that derives from traditional lands, waters and territories. This Label is being used to indicate an express interest in being a primary party to any future negotiations if future commercialization opportunities arise."@en ;
    lcont:templateText "This Label is being used to indicate that [community name or authorizing party] is open to commercialization opportunities that might derive from any information, collections, data, and digital sequence information (DSI) to which this Label is connected. As a primary party in any partnership and collaboration opportunity that emerges from the use of these resources, we retain an express interest in any future negotiations."@en ;
    skos:example "This Label is being used to indicate that Whakatohea is open to commercialisation opportunities that might derive from any information, biocultural materials and data including DSI to which this Label is connected. Whakatohea assert our right to participate in discussions and commercialisation of this taonga."@en ; 
    odrl:relatedNotice lcn:open-to-collaborate ;
    skos:relatedMatch tk:commercial ;
    skos:inScheme bccs: ;
    skos:notation "BC OC" ;
    skos:prefLabel "Open To Commercialization"@en ;
.

bc:outreach
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "outreach"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-outreach/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "This Label should be used when you would only like your biocultural materials and/or data used for educational outreach activities. Outreach activities means to share works outside the community in order to increase and raise awareness and education about your family, clan and/or community. Sites for outreach activities can include schools, universities, libraries, archives, museums, online forums, and small learning groups."@en ;
    lcont:templateText "The Label is letting any users know that this data can be used for educational outreach activities. This Label asks you to respect the designated circulation conditions for these biocultural materials and/or data and additionally, where possible, to develop a means for fair and equitable reciprocal exchange for the use of this data with the relevant BC holders."@en ; 
    skos:example ""@en ; 
    odrl:relatedNotice lcn:open-to-collaborate ;
    skos:relatedMatch tk:outreach ;
    skos:inScheme bccs: ;
    skos:notation "BC O" ;
    skos:prefLabel "Outreach"@en ;
.

bc:non-commercial
    a
        skos:Concept ,
        odrl:Policy , lcont:BCLabel ;
    dcterms:identifier "non-commercial"^^xsd:token ;
    sdo:citation "https://localcontexts.org/label/bc-non-commercial/"^^xsd:anyURI ;
    rdfs:isDefinedBy bccs: ;
    skos:definition "This Label should be used when you would like to let external users who have access to your biocultural data know that it should only be used in non-commercial ways. You are asking users to be respectful with your data and ask that it not be used to derive economic benefits or used in any way that makes it into a commodity for sale or purchase."@en ;
    lcont:templateText "This Label is being used to indicate that these biocultural materials and/or data have been designated as being available for non-commercial use. You are allowed to use this material for non-commercial purposes including for research, study, or public presentation and/or online in blogs or non-commercial websites. This Label asks you to think and act with respect and responsibility towards this data and the original custodians."@en ; 
    skos:example ""@en ; 
    odrl:relatedNotice lcn:open-to-collaborate ;
    skos:relatedMatch tk:non-commercial ;
    skos:inScheme bccs: ;
    skos:notation "BC NC" ;
    skos:prefLabel "Non-Commercial"@en ;
.

